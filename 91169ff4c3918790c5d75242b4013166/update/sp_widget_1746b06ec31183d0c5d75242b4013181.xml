<?xml version="1.0" encoding="UTF-8"?><record_update table="sp_widget">
    <sp_widget action="INSERT_OR_UPDATE">
        <category>custom</category>
        <client_script><![CDATA[function SelfRegController($http, $window) {
  var c = this;
  c.form = {};

  c.registerUser = function() {
    c.error = null;
    
    $http.post('/api/x_1834272_emergenc/public_incident_intake/submit_request', {
      type: 'registration',
      name: c.form.name,
      email: c.form.email,
      password: c.form.password
    }).then(function(response) {
      if (response.data.result && response.data.result.success) {
        c.success = "Account created successfully! Redirecting you to the sign-in window...";
        
        // This forces the browser to slide them seamlessly over to the login portal screen
        $window.setTimeout(function() {
          $window.location.href = "/sp?id=login";
        }, 1500);
      } else {
        c.error = response.data.result.error || "Registration rejected by server.";
      }
    }, function() {
      c.error = "Security configuration or email duplicate check failed.";
    });
  };
}]]></client_script>
        <controller_as>c</controller_as>
